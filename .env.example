# =============================================
# DATABASE
# =============================================
DB_URL=jdbc:postgresql://localhost:5432/db_banking
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# =============================================
# JWT - CRITICAL: Use strong random secrets!
# Generate with: openssl rand -base64 64
# =============================================
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# =============================================
# SMTP (Gmail App Password)
# See: https://support.google.com/accounts/answer/185833
# =============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=CHANGE_ME_GMAIL_APP_PASSWORD

# =============================================
# ADMIN ACCOUNT (DataInitializer)
# Use strong password with uppercase, lowercase, numbers, symbols
# =============================================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
