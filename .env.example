# Example environment variables - copy this to .env and fill in your values
# DO NOT commit .env to git!

# =============================================
# DATABASE
# =============================================
DB_URL=jdbc:postgresql://localhost:5432/db_banking
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here

# =============================================
# JWT
# =============================================
JWT_SECRET=YourVeryLongAndSecureSecretKeyThatShouldBeAtLeast64CharactersLong12345
JWT_EXPIRATION=18000000
JWT_REFRESH_EXPIRATION=604800000

# =============================================
# SMTP (Gmail example - use App Password, not real password)
# =============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# =============================================
# ADMIN ACCOUNT (DataInitializer)
# =============================================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password_here
